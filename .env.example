# ─── Variables del cliente (prefijo VITE_) ────────────────────────────────
# En producción (Vercel) VITE_APP_API_BASE debe quedar vacío → rutas relativas /api/...
VITE_APP_API_BASE=

# Base de CoinGecko (en producción se llama directo; en dev usa el proxy de Vite)
VITE_COINGECKO_BASE=https://api.coingecko.com/api/v3

# Google OAuth (opcional)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Variables del servidor (Vercel Serverless / NO exponer con VITE_) ────
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-private-upload-bucket
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SES_EMAIL=verified-sender@example.com

# En producción pon tu dominio de Vercel: https://nexopay.vercel.app
# En desarrollo local: http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173

S3_PRESIGNED_EXPIRES_IN=300

# ─── Solo para desarrollo local con servidor Express ──────────────────────
# VITE_API_BASE=http://localhost:4000/api/coingecko
