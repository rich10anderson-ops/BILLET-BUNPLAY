# Client-side variables
VITE_API_BASE=
VITE_COINGECKO_BASE=https://api.coingecko.com/api/v3
VITE_APP_API_BASE=
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Vercel serverless variables. Do not expose these with VITE_.
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-private-upload-bucket
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SES_EMAIL=verified-sender@example.com
ALLOWED_ORIGIN=http://localhost:5173
S3_PRESIGNED_EXPIRES_IN=300

# For local proxy server, set:
# VITE_API_BASE=http://localhost:4000/api/coingecko
